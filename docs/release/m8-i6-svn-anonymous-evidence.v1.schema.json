{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Hitsuki-Ban/SubversionR/blob/main/docs/release/m8-i6-svn-anonymous-evidence.v1.schema.json",
  "title": "SubversionR M8 I6 direct svn anonymous evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "contract",
    "target",
    "productVersion",
    "publicClaimEligible",
    "artifactBindings",
    "fixture",
    "surfaces",
    "negativeCells",
    "recoverySettlements",
    "stress",
    "privacy",
    "verdict"
  ],
  "properties": {
    "schema": {
      "const": "subversionr.release.m8-i6-svn-anonymous.win32-x64.v1"
    },
    "schemaVersion": {
      "const": 1
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "const": "docs/release/m8-i6-svn-anonymous-evidence.v1.schema.json"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "target": {
      "const": "win32-x64"
    },
    "productVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "publicClaimEligible": {
      "const": true
    },
    "artifactBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vsix",
        "daemon",
        "bridge",
        "stageManifest",
        "probeDriver",
        "packagedNativeProbe",
        "packagedNegativeProbe",
        "packagedAuthzDeniedProbe",
        "packagedStalledReadProbe",
        "packagedDeadlineProbe",
        "packagedCancellationProbe",
        "packagedTrustRevokedProbe",
        "packagedRecoveryBlockedProbe",
        "packagedRecoverySafeProbe",
        "packagedRecoveryIndeterminateProbe",
        "packagedRedactionProbe",
        "raSvnFaultFixture",
        "countingProxy",
        "installedStressProbe",
        "installedNegativeProbe",
        "installedAuthzDeniedProbe",
        "installedStalledReadProbe",
        "installedDeadlineProbe",
        "installedCancellationProbe",
        "installedTrustRevokedProbe",
        "installedRecoveryBlockedProbe",
        "installedRecoverySafeProbe",
        "installedRecoveryIndeterminateProbe",
        "installedRedactionProbe",
        "installedLocalEventProbe",
        "installedVsixProbe",
        "packagedCompatibilityProbe",
        "installedExtensionHostProbe",
        "raSvnOriginPatch",
        "raSvnOriginContract",
        "nativeSourceLock",
        "svn",
        "svnadmin",
        "svnserve",
        "svnserveLog"
      ],
      "properties": {
        "vsix": {
          "$ref": "#/$defs/artifact"
        },
        "daemon": {
          "$ref": "#/$defs/artifact"
        },
        "bridge": {
          "$ref": "#/$defs/artifact"
        },
        "stageManifest": {
          "$ref": "#/$defs/artifact"
        },
        "probeDriver": {
          "$ref": "#/$defs/artifact"
        },
        "packagedNativeProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedNegativeProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedAuthzDeniedProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedStalledReadProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedDeadlineProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedCancellationProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedTrustRevokedProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedRecoveryBlockedProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedRecoverySafeProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedRecoveryIndeterminateProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedRedactionProbe": {
          "$ref": "#/$defs/artifact"
        },
        "raSvnFaultFixture": {
          "$ref": "#/$defs/artifact"
        },
        "countingProxy": {
          "$ref": "#/$defs/artifact"
        },
        "installedStressProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedNegativeProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedAuthzDeniedProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedStalledReadProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedDeadlineProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedCancellationProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedTrustRevokedProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedRecoveryBlockedProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedRecoverySafeProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedRecoveryIndeterminateProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedRedactionProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedLocalEventProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedVsixProbe": {
          "$ref": "#/$defs/artifact"
        },
        "packagedCompatibilityProbe": {
          "$ref": "#/$defs/artifact"
        },
        "installedExtensionHostProbe": {
          "$ref": "#/$defs/artifact"
        },
        "raSvnOriginPatch": {
          "$ref": "#/$defs/artifact"
        },
        "raSvnOriginContract": {
          "$ref": "#/$defs/artifact"
        },
        "nativeSourceLock": {
          "$ref": "#/$defs/artifact"
        },
        "svn": {
          "$ref": "#/$defs/artifact"
        },
        "svnadmin": {
          "$ref": "#/$defs/artifact"
        },
        "svnserve": {
          "$ref": "#/$defs/artifact"
        },
        "svnserveLog": {
          "$ref": "#/$defs/artifact"
        }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transport",
        "serverKind",
        "serverVersion",
        "listenHost",
        "configurationSha256",
        "authzSha256",
        "sourceBuilt",
        "fixtureCliOnly",
        "ambientConfigExcluded",
        "saslEnabled"
      ],
      "properties": {
        "transport": {
          "const": "direct-svn"
        },
        "serverKind": {
          "const": "svnserve"
        },
        "serverVersion": {
          "const": "1.14.5"
        },
        "listenHost": {
          "const": "127.0.0.1"
        },
        "configurationSha256": {
          "$ref": "#/$defs/sha256"
        },
        "authzSha256": {
          "$ref": "#/$defs/sha256"
        },
        "sourceBuilt": {
          "const": true
        },
        "fixtureCliOnly": {
          "const": true
        },
        "ambientConfigExcluded": {
          "const": true
        },
        "saslEnabled": {
          "const": false
        }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "$ref": "#/$defs/packagedSurface"
        },
        {
          "$ref": "#/$defs/installedSurface"
        }
      ],
      "items": false
    },
    "negativeCells": {
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "prefixItems": [
        { "$ref": "#/$defs/negativeMaliciousRoot" },
        { "$ref": "#/$defs/negativeSaslOnly" },
        { "$ref": "#/$defs/negativeAuthzDenied" },
        { "$ref": "#/$defs/negativeBlackholeConnect" },
        { "$ref": "#/$defs/negativeStalledMidRead" },
        { "$ref": "#/$defs/negativeDeadline" },
        { "$ref": "#/$defs/negativeCancellation" },
        { "$ref": "#/$defs/negativeWorkerCrash" },
        { "$ref": "#/$defs/negativeDaemonDisconnect" },
        { "$ref": "#/$defs/negativeTrustRevoked" },
        { "$ref": "#/$defs/negativeRecoverySafe" },
        { "$ref": "#/$defs/negativeRecoveryIndeterminate" },
        { "$ref": "#/$defs/negativeRecoveryBlocked" },
        { "$ref": "#/$defs/negativeUnrelatedRepository" },
        { "$ref": "#/$defs/negativeLocalEventZeroNetwork" },
        { "$ref": "#/$defs/negativeRedaction" }
      ],
      "items": false
    },
    "recoverySettlements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surfaceObservations"],
      "properties": {
        "surfaceObservations": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/recoverySurfaceObservation"
          }
        }
      }
    },
    "stress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "cycles",
        "status",
        "cycleObservations",
        "subsequentObservation",
        "maxWorkerDescendantsAfterCycle",
        "maxTemporaryRootsAfterCycle",
        "maxFixtureServerChildrenAfterCycle",
        "subsequentRequestPassed"
      ],
      "properties": {
        "surface": {
          "const": "installed-vsix-extension-host"
        },
        "cycles": {
          "const": 100
        },
        "status": {
          "const": "passed"
        },
        "cycleObservations": {
          "type": "array",
          "minItems": 100,
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/stressCycleObservation"
          }
        },
        "subsequentObservation": {
          "$ref": "#/$defs/stressCycleObservation"
        },
        "maxWorkerDescendantsAfterCycle": {
          "type": "integer",
          "minimum": 0
        },
        "maxTemporaryRootsAfterCycle": {
          "type": "integer",
          "minimum": 0
        },
        "maxFixtureServerChildrenAfterCycle": {
          "type": "integer",
          "minimum": 0
        },
        "subsequentRequestPassed": {
          "const": true
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rawUrlCount", "rawPathCount", "secretTokenCount", "maxDiagnosticBytes", "boundedDiagnostics"],
      "properties": {
        "rawUrlCount": {
          "const": 0
        },
        "rawPathCount": {
          "const": 0
        },
        "secretTokenCount": {
          "const": 0
        },
        "maxDiagnosticBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 32768
        },
        "boundedDiagnostics": {
          "const": true
        }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "claim",
        "allOperationCellsPassed",
        "allNegativeCellsPassed",
        "artifactHashesMatched",
        "installedProductProved",
        "sourceBuiltFixtureProved"
      ],
      "properties": {
        "status": {
          "const": "verified"
        },
        "claim": {
          "const": "win32-x64-direct-svn-anonymous"
        },
        "allOperationCellsPassed": {
          "const": true
        },
        "allNegativeCellsPassed": {
          "const": true
        },
        "artifactHashesMatched": {
          "const": true
        },
        "installedProductProved": {
          "const": true
        },
        "sourceBuiltFixtureProved": {
          "const": true
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "sha256", "sizeBytes"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["major", "minor"],
      "properties": {
        "major": {
          "const": 1
        },
        "minor": {
          "const": 35
        }
      }
    },
    "negativeResultCode": {
      "enum": [
        "none",
        "SUBVERSIONR_REMOTE_ORIGIN_MISMATCH",
        "SUBVERSIONR_REMOTE_AUTH_UNSUPPORTED",
        "SVN_REMOTE_STATUS_AUTH_FAILED",
        "SUBVERSIONR_REMOTE_WORKER_TIMED_OUT",
        "SUBVERSIONR_REMOTE_WORKER_CANCELLED",
        "SUBVERSIONR_REMOTE_WORKER_CRASHED",
        "SUBVERSIONR_REMOTE_WORKER_DISCONNECTED",
        "SUBVERSIONR_REMOTE_TRUST_EPOCH_MISMATCH",
        "SUBVERSIONR_REMOTE_OPERATION_INDETERMINATE",
        "SUBVERSIONR_REMOTE_RECOVERY_BLOCKED"
      ]
    },
    "negativeResultReason": {
      "enum": [
        "none",
        "crossAuthorityRejected",
        "remoteCapabilityUnsupported",
        "authorizationDenied",
        "operationDeadlineExceeded",
        "operationCancelled",
        "workerContainmentFailed",
        "remoteConfigurationInvalid",
        "remoteOperationIndeterminate",
        "remoteRecoveryBlocked"
      ]
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "status",
        "serverAuth",
        "promptCount",
        "credentialSettlement",
        "reconcile",
        "diagnosticsRedacted"
      ],
      "properties": {
        "operation": {
          "enum": ["checkoutOpen", "remoteStatus", "content", "historyLog", "historyBlame", "update", "commit", "branchCopy", "switch"]
        },
        "status": {
          "const": "passed"
        },
        "serverAuth": {
          "const": "anonymous"
        },
        "promptCount": {
          "const": 0
        },
        "credentialSettlement": {
          "const": "none"
        },
        "reconcile": {
          "const": "fresh"
        },
        "temporaryRootsAfter": {
          "const": 0
        },
        "diagnosticsRedacted": {
          "const": true
        }
      }
    },
    "packagedOperation": {
      "allOf": [
        { "$ref": "#/$defs/operation" },
        { "required": ["temporaryRootsAfter"] }
      ]
    },
    "installedOperation": {
      "allOf": [
        { "$ref": "#/$defs/operation" },
        { "not": { "required": ["temporaryRootsAfter"] } }
      ]
    },
    "deadlineTiming": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clock", "timeoutMs", "elapsedMs", "cleanupSlackMs"],
      "properties": {
        "clock": { "const": "monotonic" },
        "timeoutMs": { "const": 500 },
        "elapsedMs": { "type": "number", "minimum": 500, "maximum": 5500 },
        "cleanupSlackMs": { "const": 5000 }
      }
    },
    "cancellationSettlement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "localCode", "wireCode", "wireReason", "wireSettlementObserved"],
      "properties": {
        "trigger": { "const": "abort-signal-after-greeting" },
        "localCode": { "const": "JSON_RPC_REQUEST_CANCELLED" },
        "wireCode": { "const": "SUBVERSIONR_REMOTE_WORKER_CANCELLED" },
        "wireReason": { "const": "operationCancelled" },
        "wireSettlementObserved": { "const": true }
      }
    },
    "trustTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fromEpoch", "toEpoch", "staleEnvelopeEpoch", "remoteSubmissionEnabledAfter"],
      "properties": {
        "fromEpoch": { "const": 1 },
        "toEpoch": { "const": 2 },
        "staleEnvelopeEpoch": { "const": 1 },
        "remoteSubmissionEnabledAfter": { "const": false }
      }
    },
    "stressCycleObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cycle",
        "operationIdSha256",
        "targetPathSha256",
        "extensionHostSessionSha256",
        "operation",
        "faultMode",
        "status",
        "checkoutRevision",
        "fixtureCliInvocations",
        "credentialRequests",
        "credentialSettlements",
        "workerDescendantsAfter",
        "temporaryRootsAfter",
        "fixtureServerChildrenAfter",
        "checkoutJournalEntriesAfter",
        "diagnosticsRedacted"
      ],
      "properties": {
        "cycle": {
          "type": "integer",
          "minimum": 1,
          "maximum": 101
        },
        "operationIdSha256": {
          "$ref": "#/$defs/sha256"
        },
        "targetPathSha256": {
          "$ref": "#/$defs/sha256"
        },
        "extensionHostSessionSha256": {
          "$ref": "#/$defs/sha256"
        },
        "operation": {
          "const": "checkoutOpen"
        },
        "faultMode": {
          "const": "none"
        },
        "status": {
          "const": "passed"
        },
        "checkoutRevision": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        },
        "fixtureCliInvocations": {
          "const": 0
        },
        "credentialRequests": {
          "type": "integer",
          "minimum": 0
        },
        "credentialSettlements": {
          "type": "integer",
          "minimum": 0
        },
        "workerDescendantsAfter": {
          "type": "integer",
          "minimum": 0
        },
        "temporaryRootsAfter": {
          "type": "integer",
          "minimum": 0
        },
        "fixtureServerChildrenAfter": {
          "type": "integer",
          "minimum": 0
        },
        "checkoutJournalEntriesAfter": {
          "type": "integer",
          "minimum": 0
        },
        "diagnosticsRedacted": {
          "const": true
        }
      }
    },
    "surfaceBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "artifactSha256", "protocol", "remoteSvnAnonymous", "fixtureCliInvocations", "positiveOperationCount", "identityRequiredOperationCount", "remoteOperationCount", "uniqueOperationIds", "operations", "anonymousIdentityRequired"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "artifactSha256": {
          "$ref": "#/$defs/sha256"
        },
        "protocol": {
          "$ref": "#/$defs/protocol"
        },
        "remoteSvnAnonymous": {
          "const": true
        },
        "fixtureCliInvocations": {
          "const": 0
        },
        "positiveOperationCount": {
          "const": 9
        },
        "identityRequiredOperationCount": {
          "const": 2
        },
        "remoteOperationCount": {
          "const": 11
        },
        "uniqueOperationIds": {
          "const": true
        },
        "operations": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "items": {
            "$ref": "#/$defs/operation"
          }
        },
        "anonymousIdentityRequired": {
          "$ref": "#/$defs/anonymousIdentityRequired"
        }
      }
    },
    "anonymousIdentityRequired": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lock", "unlock"],
      "properties": {
        "lock": {
          "allOf": [
            { "$ref": "#/$defs/anonymousIdentityRequiredOperation" },
            {
              "properties": {
                "operation": { "const": "lock" },
                "stableCode": { "const": "SVN_OPERATION_LOCK_FAILED" },
                "svnCauseNames": {
                  "allOf": [
                    { "contains": { "const": "SVN_ERR_RA_NOT_AUTHORIZED" }, "minContains": 1, "maxContains": 1 },
                    { "not": { "contains": { "const": "SVN_ERR_FS_NO_USER" } } }
                  ]
                }
              }
            }
          ]
        },
        "unlock": {
          "allOf": [
            { "$ref": "#/$defs/anonymousIdentityRequiredOperation" },
            {
              "properties": {
                "operation": { "const": "unlock" },
                "stableCode": { "const": "SVN_OPERATION_UNLOCK_FAILED" },
                "svnCauseNames": {
                  "allOf": [
                    { "contains": { "const": "SVN_ERR_FS_NO_USER" }, "minContains": 1, "maxContains": 1 },
                    { "not": { "contains": { "const": "SVN_ERR_RA_NOT_AUTHORIZED" } } }
                  ]
                }
              }
            }
          ]
        }
      }
    },
    "anonymousIdentityRequiredOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "anonymousIdentityRequired", "stableCode", "diagnosticsCause", "mayHaveMutated", "remoteFailure", "promptCount", "credentialSettlement", "laneReleaseProof", "nativeLaneReleased", "diagnosticsRedacted", "svnCauseNames"],
      "properties": {
        "operation": { "enum": ["lock", "unlock"] },
        "anonymousIdentityRequired": { "const": true },
        "stableCode": { "enum": ["SVN_OPERATION_LOCK_FAILED", "SVN_OPERATION_UNLOCK_FAILED"] },
        "diagnosticsCause": { "const": "authenticationFailed" },
        "mayHaveMutated": { "const": false },
        "remoteFailure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["category", "reason", "cleanupAppropriate"],
          "properties": {
            "category": { "const": "authentication" },
            "reason": { "const": "authenticationRequired" },
            "cleanupAppropriate": { "const": false }
          }
        },
        "promptCount": { "const": 0 },
        "credentialSettlement": { "const": "none" },
        "temporaryRootsAfter": { "const": 0 },
        "laneReleaseProof": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "reconcile"],
          "properties": {
            "method": { "const": "status/refresh" },
            "reconcile": { "const": "fresh" }
          }
        },
        "nativeLaneReleased": { "const": true },
        "diagnosticsRedacted": { "const": true },
        "svnCauseNames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^SVN_ERR_[A-Z0-9_]+$" },
          "contains": { "enum": ["SVN_ERR_RA_NOT_AUTHORIZED", "SVN_ERR_FS_NO_USER"] },
          "minContains": 1,
          "maxContains": 1
        }
      }
    },
    "packagedAnonymousIdentityRequired": {
      "allOf": [
        { "$ref": "#/$defs/anonymousIdentityRequired" },
        {
          "properties": {
            "lock": { "required": ["temporaryRootsAfter"] },
            "unlock": { "required": ["temporaryRootsAfter"] }
          }
        }
      ]
    },
    "installedAnonymousIdentityRequired": {
      "allOf": [
        { "$ref": "#/$defs/anonymousIdentityRequired" },
        {
          "properties": {
            "lock": { "not": { "required": ["temporaryRootsAfter"] } },
            "unlock": { "not": { "required": ["temporaryRootsAfter"] } }
          }
        }
      ]
    },
    "packagedSurface": {
      "allOf": [
        {
          "$ref": "#/$defs/surfaceBase"
        },
        {
          "properties": {
            "kind": {
              "const": "packaged-native"
            },
            "operations": {
              "items": { "$ref": "#/$defs/packagedOperation" }
            },
            "anonymousIdentityRequired": {
              "$ref": "#/$defs/packagedAnonymousIdentityRequired"
            }
          }
        }
      ]
    },
    "installedSurface": {
      "allOf": [
        {
          "$ref": "#/$defs/surfaceBase"
        },
        {
          "properties": {
            "kind": {
              "const": "installed-vsix-extension-host"
            },
            "operations": {
              "items": { "$ref": "#/$defs/installedOperation" }
            },
            "anonymousIdentityRequired": {
              "$ref": "#/$defs/installedAnonymousIdentityRequired"
            }
          }
        }
      ]
    },
    "negativeSurfaceObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "originCode",
        "originReason",
        "settlementCode",
        "settlementReason",
        "networkProgress",
        "networkAttempts",
        "networkConnections",
        "fixtureCliInvocations",
        "credentialRequests",
        "credentialSettlements",
        "followupNetworkContacts",
        "workerDescendantsAfter",
        "temporaryRootsAfter",
        "diagnosticsRedacted"
      ],
      "properties": {
        "surface": {
          "enum": ["packaged-native", "installed-vsix-extension-host"]
        },
        "originCode": {
          "$ref": "#/$defs/negativeResultCode"
        },
        "originReason": {
          "$ref": "#/$defs/negativeResultReason"
        },
        "settlementCode": {
          "$ref": "#/$defs/negativeResultCode"
        },
        "settlementReason": {
          "$ref": "#/$defs/negativeResultReason"
        },
        "networkProgress": {
          "enum": ["none", "connected", "greeting", "authenticated", "command"]
        },
        "networkAttempts": {
          "type": "integer",
          "minimum": 0
        },
        "networkConnections": {
          "type": "integer",
          "minimum": 0
        },
        "fixtureCliInvocations": {
          "const": 0
        },
        "credentialRequests": {
          "const": 0
        },
        "credentialSettlements": {
          "const": 0
        },
        "followupNetworkContacts": {
          "const": 0
        },
        "workerDescendantsAfter": {
          "const": 0
        },
        "temporaryRootsAfter": {
          "const": 0
        },
        "diagnosticsRedacted": {
          "const": true
        },
        "deadlineTiming": {
          "$ref": "#/$defs/deadlineTiming"
        },
        "cancellationSettlement": {
          "$ref": "#/$defs/cancellationSettlement"
        },
        "trustTransition": {
          "$ref": "#/$defs/trustTransition"
        }
      }
    },
    "recoverySurfaceObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "safe", "indeterminate", "blocked"],
      "properties": {
        "surface": {
          "enum": ["packaged-native", "installed-vsix-extension-host"]
        },
        "safe": {
          "type": "object",
          "additionalProperties": false,
          "required": ["outcome", "freshReconcile", "nativeLaneReleased", "subsequentRequestPassed"],
          "properties": {
            "outcome": { "const": "Safe" },
            "freshReconcile": { "const": true },
            "nativeLaneReleased": { "const": true },
            "subsequentRequestPassed": { "const": true }
          }
        },
        "indeterminate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["outcome", "stableCode", "reason", "nativeLaneBlocked", "explicitRecoveryRequired"],
          "properties": {
            "outcome": { "const": "Indeterminate" },
            "stableCode": { "const": "SUBVERSIONR_REMOTE_OPERATION_INDETERMINATE" },
            "reason": { "const": "remoteOperationIndeterminate" },
            "nativeLaneBlocked": { "const": true },
            "explicitRecoveryRequired": { "const": true }
          }
        },
        "blocked": {
          "type": "object",
          "additionalProperties": false,
          "required": ["outcome", "stableCode", "reason", "restartRestoredBlocked", "automaticClear", "requiredConfirmation", "armedTargetPathSha256", "confirmedTargetPathSha256", "armedOriginOperationIdSha256", "confirmedOriginOperationIdSha256", "confirmedEntryRemoved", "subsequentCheckoutPassed"],
          "properties": {
            "outcome": { "const": "Blocked" },
            "stableCode": { "const": "SUBVERSIONR_REMOTE_RECOVERY_BLOCKED" },
            "reason": { "const": "remoteRecoveryBlocked" },
            "restartRestoredBlocked": { "const": true },
            "automaticClear": { "const": false },
            "requiredConfirmation": { "const": "reviewedAndResolved" },
            "armedTargetPathSha256": { "$ref": "#/$defs/sha256" },
            "confirmedTargetPathSha256": { "$ref": "#/$defs/sha256" },
            "armedOriginOperationIdSha256": { "$ref": "#/$defs/sha256" },
            "confirmedOriginOperationIdSha256": { "$ref": "#/$defs/sha256" },
            "confirmedEntryRemoved": { "const": true },
            "subsequentCheckoutPassed": { "const": true }
          }
        }
      }
    },
    "negativeCell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cell",
        "status",
        "stableCode",
        "reason",
        "surfaceObservations"
      ],
      "properties": {
        "cell": {
          "enum": [
            "maliciousRoot",
            "saslOnly",
            "authzDenied",
            "blackholeConnect",
            "stalledMidRead",
            "deadline",
            "cancellation",
            "workerCrash",
            "daemonDisconnect",
            "trustRevoked",
            "recoverySafe",
            "recoveryIndeterminate",
            "recoveryBlocked",
            "unrelatedRepository",
            "localEventZeroNetwork",
            "redaction"
          ]
        },
        "status": {
          "const": "passed"
        },
        "stableCode": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "surfaceObservations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/negativeSurfaceObservation"
          }
        }
      }
    },
    "negativeMaliciousRoot": {
      "$ref": "#/$defs/negativeCell",
      "properties": { "cell": { "const": "maliciousRoot" }, "stableCode": { "const": "SUBVERSIONR_REMOTE_ORIGIN_MISMATCH" }, "reason": { "const": "crossAuthorityRejected" } }
    },
    "negativeSaslOnly": {
      "$ref": "#/$defs/negativeCell",
      "properties": { "cell": { "const": "saslOnly" }, "stableCode": { "const": "SUBVERSIONR_REMOTE_AUTH_UNSUPPORTED" }, "reason": { "const": "remoteCapabilityUnsupported" } }
    },
    "negativeAuthzDenied": {
      "$ref": "#/$defs/negativeCell",
      "properties": { "cell": { "const": "authzDenied" }, "stableCode": { "const": "SVN_REMOTE_STATUS_AUTH_FAILED" }, "reason": { "const": "authorizationDenied" } }
    },
    "negativeBlackholeConnect": {
      "$ref": "#/$defs/negativeCell",
      "properties": { "cell": { "const": "blackholeConnect" }, "stableCode": { "const": "SUBVERSIONR_REMOTE_WORKER_TIMED_OUT" }, "reason": { "const": "operationDeadlineExceeded" } }
    },
    "negativeStalledMidRead": {
      "$ref": "#/$defs/negativeCell",
      "properties": { "cell": { "const": "stalledMidRead" }, "stableCode": { "const": "SUBVERSIONR_REMOTE_WORKER_TIMED_OUT" }, "reason": { "const": "operationDeadlineExceeded" } }
    },
    "negativeDeadline": {
      "$ref": "#/$defs/negativeCell",
      "properties": {
        "cell": { "const": "deadline" },
        "stableCode": { "const": "SUBVERSIONR_REMOTE_WORKER_TIMED_OUT" },
        "reason": { "const": "operationDeadlineExceeded" },
        "surfaceObservations": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "allOf": [
              { "$ref": "#/$defs/negativeSurfaceObservation" },
              { "required": ["deadlineTiming"] }
            ]
          }
        }
      }
    },
    "negativeCancellation": {
      "$ref": "#/$defs/negativeCell",
      "properties": {
        "cell": { "const": "cancellation" },
        "stableCode": { "const": "SUBVERSIONR_REMOTE_WORKER_CANCELLED" },
        "reason": { "const": "operationCancelled" },
        "surfaceObservations": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "allOf": [
              { "$ref": "#/$defs/negativeSurfaceObservation" },
              { "required": ["cancellationSettlement"] }
            ]
          }
        }
      }
    },
    "negativeWorkerCrash": {
      "$ref": "#/$defs/negativeCell",
      "properties": { "cell": { "const": "workerCrash" }, "stableCode": { "const": "SUBVERSIONR_REMOTE_WORKER_CRASHED" }, "reason": { "const": "workerContainmentFailed" } }
    },
    "negativeDaemonDisconnect": {
      "$ref": "#/$defs/negativeCell",
      "properties": { "cell": { "const": "daemonDisconnect" }, "stableCode": { "const": "SUBVERSIONR_REMOTE_WORKER_DISCONNECTED" }, "reason": { "const": "workerContainmentFailed" } }
    },
    "negativeTrustRevoked": {
      "$ref": "#/$defs/negativeCell",
      "properties": {
        "cell": { "const": "trustRevoked" },
        "stableCode": { "const": "SUBVERSIONR_REMOTE_TRUST_EPOCH_MISMATCH" },
        "reason": { "const": "remoteConfigurationInvalid" },
