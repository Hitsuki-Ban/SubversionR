+static svn_error_t *
+subversionr_authority_mismatch(void)
+{
+  return svn_error_create(SVN_ERR_RA_ILLEGAL_URL, NULL,
+                          "SubversionR repository root authority mismatch");
+}
+
+/* Validate an authenticated server-selected repository root before it is
+   stored or used.  The private auth parameter is set only by SubversionR's
+   envelope-validated direct svn transport. */
+static svn_error_t *
+subversionr_validate_repos_root(const char **validated_root,
+                                const char *server_root,
+                                const char *request_url,
+                                const apr_uri_t *request_uri,
+                                svn_auth_baton_t *auth_baton,
+                                apr_pool_t *result_pool,
+                                apr_pool_t *scratch_pool)
+{
+  const char *expected_authority = svn_auth_get_parameter(
+      auth_baton, SUBVERSIONR_AUTH_PARAM_RA_SVN_EXPECTED_AUTHORITY);
+  const char *canonical_request;
+  const char *canonical_expected;
+  const char *canonical_server_root;
+  apr_uri_t expected_uri;
+  apr_uri_t root_uri;
+  apr_status_t status;
+  svn_error_t *err;
+
+  if (! server_root)
+    return expected_authority ? subversionr_authority_mismatch()
+                              : SVN_NO_ERROR;
+
+  if (! expected_authority)
+    {
+      SVN_ERR(svn_uri_canonicalize_safe(&canonical_server_root, NULL,
+                                        server_root, result_pool,
+                                        scratch_pool));
+      if (strlen(canonical_server_root) > strlen(request_url))
+        return svn_error_create(SVN_ERR_RA_SVN_MALFORMED_DATA, NULL,
+                                _("Impossibly long repository root from "
+                                  "server"));
+      *validated_root = canonical_server_root;
+      return SVN_NO_ERROR;
+    }
+
+  err = svn_uri_canonicalize_safe(&canonical_server_root, NULL, server_root,
+                                  result_pool, scratch_pool);
+  if (err)
+    {
+      svn_error_clear(err);
+      return subversionr_authority_mismatch();
+    }
+  err = svn_uri_canonicalize_safe(&canonical_expected, NULL,
+                                  expected_authority, scratch_pool,
+                                  scratch_pool);
+  if (err)
+    {
+      svn_error_clear(err);
+      return subversionr_authority_mismatch();
+    }
+  err = svn_uri_canonicalize_safe(&canonical_request, NULL, request_url,
+                                  scratch_pool, scratch_pool);
+  if (err)
+    {
+      svn_error_clear(err);
+      return subversionr_authority_mismatch();
+    }
+
+  status = apr_uri_parse(scratch_pool, canonical_expected, &expected_uri);
+  if (status != APR_SUCCESS || ! expected_uri.scheme ||
+      ! expected_uri.hostname || strcmp(expected_uri.scheme, "svn") != 0 ||
+      expected_uri.user || expected_uri.password || expected_uri.query ||
+      expected_uri.fragment ||
+      (expected_uri.path && expected_uri.path[0] != '\0' &&
+       strcmp(expected_uri.path, "/") != 0))
+    return subversionr_authority_mismatch();
+
+  if (! request_uri->scheme || ! request_uri->hostname ||
+      strcmp(request_uri->scheme, expected_uri.scheme) != 0 ||
+      strcmp(request_uri->hostname, expected_uri.hostname) != 0 ||
+      (request_uri->port_str ? request_uri->port : SVN_RA_SVN_PORT) !=
+      (expected_uri.port_str ? expected_uri.port : SVN_RA_SVN_PORT))
+    return subversionr_authority_mismatch();
+
+  status = apr_uri_parse(scratch_pool, canonical_server_root, &root_uri);
+  if (status != APR_SUCCESS || ! root_uri.scheme || ! root_uri.hostname ||
+      root_uri.user || root_uri.password || root_uri.query ||
+      root_uri.fragment ||
+      strcmp(root_uri.scheme, expected_uri.scheme) != 0 ||
+      strcmp(root_uri.hostname, expected_uri.hostname) != 0 ||
+      (root_uri.port_str ? root_uri.port : SVN_RA_SVN_PORT) !=
+      (expected_uri.port_str ? expected_uri.port : SVN_RA_SVN_PORT) ||
+      svn_uri_skip_ancestor(canonical_server_root, canonical_request,
+                            scratch_pool) == NULL)
+    return subversionr_authority_mismatch();
+
+  *validated_root = canonical_server_root;
+  return SVN_NO_ERROR;
+}
